FROM node:24-slim
WORKDIR /app

COPY relay/package.json relay/package-lock.json* ./relay/
RUN cd relay && npm install --omit=dev

COPY relay/*.mjs ./relay/

USER node
EXPOSE 8788

HEALTHCHECK --interval=10s --timeout=3s --retries=3 \
  CMD node -e "fetch('http://localhost:8788/health').then(r=>r.ok?process.exit(0):process.exit(1)).catch(()=>process.exit(1))"

CMD ["node", "relay/index.mjs"]
